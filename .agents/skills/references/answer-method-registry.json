{
  "coverage-ceiling-measurement": {
    "mandatory_nodes": [
      "full workflow scope inventory",
      "major removable source",
      "ceiling coverage criterion",
      "candidate coverage matrix",
      "same-workload full workflow run",
      "interpretation against coverage matrix"
    ],
    "forbidden_substitutions": [
      "full-workflow-run-validation"
    ],
    "minimum_evidence": [
      "workflow scope inventory",
      "removable source or bottleneck inventory",
      "coverage criterion",
      "coverage matrix",
      "same-workload run evidence",
      "interpretation against coverage matrix"
    ],
    "review_red_flags": [
      "candidate path run is treated as ceiling coverage",
      "same-workload checks pass without source coverage",
      "single bottleneck result is reported as whole-workflow ceiling"
    ]
  },
  "implementation-spine": {
    "mandatory_nodes": [
      "initial state",
      "state transition that makes the result true",
      "observable target state"
    ],
    "forbidden_substitutions": [
      "component-inventory-completion"
    ],
    "minimum_evidence": [
      "transition evidence",
      "integration evidence"
    ],
    "review_red_flags": [
      "components are complete but the actor path is unobserved"
    ]
  },
  "measurement-protocol": {
    "mandatory_nodes": [
      "measurement scope",
      "measurement protocol",
      "execution evidence",
      "interpretation"
    ],
    "forbidden_substitutions": [
      "single-run-validation"
    ],
    "minimum_evidence": [
      "scope evidence",
      "protocol evidence",
      "measurement evidence"
    ],
    "review_red_flags": [
      "run evidence appears without protocol adequacy"
    ]
  },
  "claim-evidence-audit": {
    "mandatory_nodes": [
      "claim inventory",
      "evidence inventory",
      "claim-evidence mapping",
      "unsupported claim disposition"
    ],
    "forbidden_substitutions": [
      "checklist-completion"
    ],
    "minimum_evidence": [
      "claim table",
      "evidence table",
      "mapping table"
    ],
    "review_red_flags": [
      "checklist is complete but claim support is unclassified"
    ]
  },
  "diagnosis-discrimination": {
    "mandatory_nodes": [
      "hypothesis set",
      "discriminating observation",
      "observation result",
      "hypothesis disposition"
    ],
    "forbidden_substitutions": [
      "generic-audit"
    ],
    "minimum_evidence": [
      "hypothesis table",
      "discriminating evidence",
      "disposition"
    ],
    "review_red_flags": [
      "findings are listed without discriminating hypotheses"
    ]
  }
}
