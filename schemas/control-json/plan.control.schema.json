{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/plan.control.schema.json",
  "title": "Cybernetic Execution Plan Control",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "status",
    "source_contracts",
    "semantic_base_ref",
    "registry_bindings",
    "required_steps",
    "step_action_alignment",
    "work_packages",
    "runtime",
    "progress",
    "verifier"
  ],
  "properties": {
    "artifact_type": {
      "const": "plan.control"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "approved",
        "candidate"
      ]
    },
    "source_contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirements",
        "design",
        "goal"
      ],
      "properties": {
        "requirements": {
          "type": "string",
          "minLength": 1
        },
        "design": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "semantic_base_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "approved_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_coverage",
        "action_that_can_make_it_done"
      ],
      "properties": {
        "work_coverage": {
          "type": "string",
          "minLength": 1
        },
        "action_that_can_make_it_done": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "registry_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_agent_workflow",
        "allowed_work_assignment"
      ],
      "properties": {
        "selected_agent_workflow": {
          "type": "string",
          "minLength": 1
        },
        "allowed_work_assignment": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "required_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "transition",
          "evidence",
          "satisfies_outcomes"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "transition": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "satisfies_outcomes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "work_packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "work_package_id",
          "role",
          "required_steps",
          "uses_step_action_alignment",
          "state_change_it_produces",
          "not_merely_verification",
          "counts_as_goal_progress",
          "allowed_write_paths",
          "forbidden_write_paths",
          "required_tests"
        ],
        "properties": {
          "work_package_id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "enum": [
              "mainline",
              "supporting-only"
            ]
          },
          "required_steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "uses_step_action_alignment": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "state_change_it_produces": {
            "type": "string",
            "minLength": 1
          },
          "not_merely_verification": {
            "type": "boolean"
          },
          "counts_as_goal_progress": {
            "type": "boolean"
          },
          "allowed_write_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forbidden_write_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_tests": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "step_action_alignment": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "required_step_id",
          "what_would_make_it_true",
          "current_state",
          "planned_producing_action",
          "why_this_can_make_it_true",
          "allowed_authority_needed",
          "evidence_after_action",
          "if_not_producible"
        ],
        "properties": {
          "required_step_id": {
            "type": "string",
            "minLength": 1
          },
          "what_would_make_it_true": {
            "type": "string",
            "minLength": 1
          },
          "current_state": {
            "type": "string",
            "minLength": 1
          },
          "planned_producing_action": {
            "type": "string",
            "minLength": 1
          },
          "why_this_can_make_it_true": {
            "type": "string",
            "minLength": 1
          },
          "allowed_authority_needed": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "write_paths",
              "run_commands"
            ],
            "properties": {
              "write_paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "run_commands": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "evidence_after_action": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "if_not_producible": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readonly_files",
        "writable_files",
        "writable_evidence_paths"
      ],
      "properties": {
        "readonly_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "writable_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "writable_evidence_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_schema",
        "append_only"
      ],
      "properties": {
        "event_schema": {
          "type": "string",
          "minLength": 1
        },
        "append_only": {
          "type": "boolean"
        }
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_before_goal_achieved",
        "required_outcomes",
        "output_schema"
      ],
      "properties": {
        "required_before_goal_achieved": {
          "type": "boolean"
        },
        "required_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_schema": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
