{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/requirements.control.schema.json",
  "title": "Cybernetic Requirements Control",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "status",
    "approved_control",
    "registry_bindings"
  ],
  "properties": {
    "artifact_type": {
      "const": "requirements.control"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "approved"
      ]
    },
    "approved_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_purpose",
        "primary_object",
        "requested_transformation",
        "non_goals",
        "how_we_know_purpose_was_met",
        "where_result_must_show_up",
        "what_counts_as_done",
        "required_outcomes",
        "final_answer_format",
        "semantic_base"
      ],
      "properties": {
        "human_purpose": {
          "type": "string",
          "minLength": 1
        },
        "primary_object": {
          "type": "string",
          "minLength": 1
        },
        "requested_transformation": {
          "type": "string",
          "minLength": 1
        },
        "non_goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "how_we_know_purpose_was_met": {
          "type": "string",
          "minLength": 1
        },
        "where_result_must_show_up": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "what_counts_as_done": {
          "type": "string",
          "minLength": 1
        },
        "required_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "statement",
              "blocks_goal_achieved_if_missing",
              "required_evidence",
              "not_satisfied_by"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "blocks_goal_achieved_if_missing": {
                "type": "boolean"
              },
              "required_evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "evidence_id",
                    "kind",
                    "description"
                  ],
                  "properties": {
                    "evidence_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "kind": {
                      "enum": [
                        "progress_event",
                        "file_exists",
                        "json_file",
                        "command_result"
                      ]
                    },
                    "description": {
                      "type": "string",
                      "minLength": 1
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "schema": {
                      "type": "string",
                      "minLength": 1
                    },
                    "command": {
                      "type": "string",
                      "minLength": 1
                    },
                    "must_pass": {
                      "type": "boolean"
                    }
                  }
                }
              },
              "not_satisfied_by": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "final_answer_format": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "medium",
            "required_structure"
          ],
          "properties": {
            "medium": {
              "type": "string",
              "minLength": 1
            },
            "required_structure": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "semantic_base": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "hash"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "hash": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "registry_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "answer_method_key",
        "forbidden_substitute_key"
      ],
      "properties": {
        "answer_method_key": {
          "type": "string",
          "minLength": 1
        },
        "forbidden_substitute_key": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
