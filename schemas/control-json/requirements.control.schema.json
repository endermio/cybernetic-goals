{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/requirements.control.schema.json",
  "title": "Cybernetic Requirements Control",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "status",
    "approved_control"
  ],
  "properties": {
    "artifact_type": {
      "const": "requirements.control"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "approved"
      ]
    },
    "approved_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_purpose",
        "primary_object",
        "requested_transformation",
        "non_goals",
        "how_we_know_purpose_was_met",
        "where_result_must_show_up",
        "what_counts_as_done",
        "required_outcomes",
        "final_answer_format",
        "semantic_base"
      ],
      "properties": {
        "human_purpose": {
          "type": "string",
          "minLength": 1
        },
        "primary_object": {
          "type": "string",
          "minLength": 1
        },
        "requested_transformation": {
          "type": "string",
          "minLength": 1
        },
        "non_goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "how_we_know_purpose_was_met": {
          "type": "string",
          "minLength": 1
        },
        "where_result_must_show_up": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "what_counts_as_done": {
          "type": "string",
          "minLength": 1
        },
        "source_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "source",
              "required_action",
              "requirement_type",
              "required_evidence_strength",
              "completion_checks",
              "blocks_goal_achieved_if_missing"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind"
                ],
                "properties": {
                  "kind": {
                    "enum": [
                      "user_message",
                      "approved_summary",
                      "requirements_review"
                    ]
                  },
                  "quote": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reference": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "anyOf": [
                  {
                    "required": [
                      "quote"
                    ]
                  },
                  {
                    "required": [
                      "reference"
                    ]
                  }
                ]
              },
              "required_action": {
                "type": "string",
                "minLength": 1
              },
              "requirement_type": {
                "enum": [
                  "implement_behavior",
                  "produce_empirical_measurement",
                  "analyze_existing_evidence",
                  "define_framework_or_plan",
                  "write_documentation",
                  "verify_or_review",
                  "diagnose_root_cause",
                  "decide_or_classify"
                ]
              },
              "required_evidence_strength": {
                "enum": [
                  "behavior_exists",
                  "measured_curve_data",
                  "benchmark_result",
                  "analysis_report",
                  "framework_document",
                  "review_report",
                  "command_result",
                  "code_change",
                  "test_result"
                ]
              },
              "target_objects": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "completion_checks": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "blocks_goal_achieved_if_missing": {
                "type": "boolean"
              }
            }
          }
        },
        "required_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "statement",
              "blocks_goal_achieved_if_missing",
              "required_evidence",
              "not_satisfied_by"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "source_requirements": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "completion_claim": {
                "type": "string",
                "minLength": 1
              },
              "completed_target_objects": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "blocks_goal_achieved_if_missing": {
                "type": "boolean"
              },
              "required_evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "evidence_id",
                    "kind",
                    "description"
                  ],
                  "properties": {
                    "evidence_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "kind": {
                      "enum": [
                        "progress_event",
                        "file_exists",
                        "json_file",
                        "command_result"
                      ]
                    },
                    "description": {
                      "type": "string",
                      "minLength": 1
                    },
                    "evidence_strength": {
                      "enum": [
                        "behavior_exists",
                        "measured_curve_data",
                        "benchmark_result",
                        "analysis_report",
                        "framework_document",
                        "review_report",
                        "command_result",
                        "code_change",
                        "test_result"
                      ]
                    },
                    "satisfies_source_requirements": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "evidence_claim": {
                      "type": "string",
                      "minLength": 1
                    },
                    "completed_target_objects": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "schema": {
                      "type": "string",
                      "minLength": 1
                    },
                    "command": {
                      "type": "string",
                      "minLength": 1
                    },
                    "must_pass": {
                      "type": "boolean"
                    }
                  }
                }
              },
              "not_satisfied_by": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "counterexample_gate_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "quality_standard",
            "required_checked_transformations",
            "minimum_reviewer",
            "reject_if"
          ],
          "properties": {
            "quality_standard": {
              "type": "string",
              "minLength": 1
            },
            "required_checked_transformations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "minimum_reviewer": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "allowed_kinds",
                "independence",
                "evidence_ref_required"
              ],
              "properties": {
                "allowed_kinds": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "enum": [
                      "subagent",
                      "human",
                      "external"
                    ]
                  }
                },
                "independence": {
                  "type": "string",
                  "minLength": 1
                },
                "evidence_ref_required": {
                  "type": "boolean"
                }
              }
            },
            "reject_if": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "final_answer_format": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "medium",
            "required_structure"
          ],
          "properties": {
            "medium": {
              "type": "string",
              "minLength": 1
            },
            "required_structure": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "semantic_base": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "hash"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "hash": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "1.1.0"
          }
        }
      },
      "then": {
        "properties": {
          "approved_control": {
            "required": [
              "source_requirements",
              "counterexample_gate_contract"
            ],
            "properties": {
              "required_outcomes": {
                "type": "array",
                "items": {
                  "required": [
                    "source_requirements",
                    "completion_claim"
                  ],
                  "properties": {
                    "required_evidence": {
                      "type": "array",
                      "items": {
                        "required": [
                          "evidence_strength",
                          "satisfies_source_requirements",
                          "evidence_claim"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
