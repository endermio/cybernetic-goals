{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/review.control.schema.json",
  "title": "Cybernetic Review Control",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "status",
    "source_contracts",
    "semantic_base_ref",
    "registry_bindings",
    "approved_control_hashes",
    "review_checks"
  ],
  "properties": {
    "artifact_type": {
      "const": "review.control"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "approved",
        "needs_revision",
        "rejected"
      ]
    },
    "source_contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirements",
        "design",
        "goal",
        "plan"
      ],
      "properties": {
        "requirements": {
          "type": "string",
          "minLength": 1
        },
        "design": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "plan": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "semantic_base_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "registry_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_agent_workflow"
      ],
      "properties": {
        "selected_agent_workflow": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "approved_control_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirements.control.json",
        "design.control.json",
        "goal.control.json",
        "plan.control.json"
      ],
      "properties": {
        "requirements.control.json": {
          "type": "string",
          "minLength": 1
        },
        "design.control.json": {
          "type": "string",
          "minLength": 1
        },
        "goal.control.json": {
          "type": "string",
          "minLength": 1
        },
        "plan.control.json": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "status",
          "verdict",
          "return_to_stage",
          "evidence",
          "findings",
          "required_changes",
          "checked_transformations"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "needs_revision"
            ]
          },
          "verdict": {
            "enum": [
              "approved",
              "needs_revision",
              "blocked"
            ]
          },
          "return_to_stage": {
            "enum": [
              null,
              "requirements",
              "design",
              "goal",
              "plan",
              "review"
            ]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_changes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "checked_transformations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
