{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/run.control.schema.json",
  "title": "Cybernetic Generation-Aware Run Control",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "status",
    "run_id",
    "control_mode",
    "current_generation",
    "semantic_base_ref",
    "amendment_policy",
    "generations"
  ],
  "properties": {
    "artifact_type": {
      "const": "run.control"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "active",
        "complete",
        "blocked"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "control_mode": {
      "enum": [
        "lean",
        "full"
      ]
    },
    "current_generation": {
      "type": "string",
      "minLength": 1
    },
    "max_auto_amendment_rounds": {
      "type": "integer"
    },
    "semantic_base_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "amendment_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "may_change",
        "must_not_change_without_human"
      ],
      "properties": {
        "may_change": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "must_not_change_without_human": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "generations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "runtime"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "active",
              "superseded",
              "candidate",
              "blocked"
            ]
          },
          "parent": {
            "type": "string",
            "minLength": 1
          },
          "runtime": {
            "type": "string",
            "minLength": 1
          },
          "review": {
            "type": "string",
            "minLength": 1
          },
          "amendment_source": {
            "type": "string",
            "minLength": 1
          },
          "required_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "step_id",
                "transition",
                "evidence",
                "satisfies_outcomes"
              ],
              "properties": {
                "step_id": {
                  "type": "string",
                  "minLength": 1
                },
                "transition": {
                  "type": "string",
                  "minLength": 1
                },
                "evidence": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "satisfies_outcomes": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
