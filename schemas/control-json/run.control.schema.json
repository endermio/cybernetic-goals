{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/run.control.schema.json",
  "title": "Cybernetic Generation-Aware Run Control",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "status",
    "run_id",
    "control_level",
    "target_model",
    "strategy_policy",
    "gate_mode",
    "phase_structure",
    "current_generation",
    "max_auto_amendment_rounds",
    "semantic_base_ref",
    "amendment_policy",
    "generations"
  ],
  "properties": {
    "artifact_type": {
      "const": "run.control"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "active",
        "complete",
        "blocked"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "control_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "target_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_orientation",
        "result_content",
        "path",
        "result_placement",
        "impact_scope"
      ],
      "properties": {
        "result_orientation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "state_change",
              "knowledge_production",
              "judgment",
              "design_model"
            ]
          }
        },
        "result_content": {
          "enum": [
            "specified",
            "partially_specified",
            "discover_during_work"
          ]
        },
        "path": {
          "enum": [
            "known_enough",
            "partially_known",
            "discover_during_work"
          ]
        },
        "result_placement": {
          "enum": [
            "single_place",
            "multi_place",
            "not_applicable"
          ]
        },
        "impact_scope": {
          "enum": [
            "local_reversible",
            "persistent_internal",
            "live_external_or_irreversible"
          ]
        }
      }
    },
    "strategy_policy": {
      "enum": [
        "frozen_strategy",
        "reviewed_replanning"
      ]
    },
    "gate_mode": {
      "enum": [
        "none",
        "human_gate",
        "live_gate"
      ]
    },
    "phase_structure": {
      "enum": [
        "single_phase",
        "staged",
        "adaptive_loop"
      ]
    },
    "current_generation": {
      "type": "string",
      "minLength": 1
    },
    "max_auto_amendment_rounds": {
      "type": "integer"
    },
    "semantic_base_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "amendment_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "may_change",
        "must_not_change_without_human"
      ],
      "properties": {
        "may_change": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "must_not_change_without_human": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "generations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "strategy_kind",
          "status",
          "runtime"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "strategy_kind": {
            "enum": [
              "discovery",
              "execution",
              "amendment"
            ]
          },
          "status": {
            "enum": [
              "active",
              "superseded",
              "candidate",
              "blocked"
            ]
          },
          "parent": {
            "type": "string",
            "minLength": 1
          },
          "runtime": {
            "type": "string",
            "minLength": 1
          },
          "review": {
            "type": "string",
            "minLength": 1
          },
          "amendment_source": {
            "type": "string",
            "minLength": 1
          },
          "required_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "step_id",
                "transition",
                "evidence",
                "satisfies_outcomes"
              ],
              "properties": {
                "step_id": {
                  "type": "string",
                  "minLength": 1
                },
                "transition": {
                  "type": "string",
                  "minLength": 1
                },
                "evidence": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "satisfies_outcomes": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "synthetic": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    }
  }
}
