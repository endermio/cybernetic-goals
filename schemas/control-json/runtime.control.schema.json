{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/runtime.control.schema.json",
  "title": "Cybernetic Runtime Control",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "status",
    "control_level",
    "target_model",
    "strategy_policy",
    "gate_mode",
    "phase_structure",
    "generation",
    "semantic_base_ref",
    "approved_control_hashes",
    "runtime",
    "required_steps",
    "progress",
    "verifier"
  ],
  "properties": {
    "artifact_type": {
      "const": "runtime.control"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "compiled"
      ]
    },
    "control_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "target_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_orientation",
        "result_content",
        "path",
        "result_placement",
        "impact_scope"
      ],
      "properties": {
        "result_orientation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "state_change",
              "knowledge_production",
              "judgment",
              "design_model"
            ]
          }
        },
        "result_content": {
          "enum": [
            "specified",
            "partially_specified",
            "discover_during_work"
          ]
        },
        "path": {
          "enum": [
            "known_enough",
            "partially_known",
            "discover_during_work"
          ]
        },
        "result_placement": {
          "enum": [
            "single_place",
            "multi_place",
            "not_applicable"
          ]
        },
        "impact_scope": {
          "enum": [
            "local_reversible",
            "persistent_internal",
            "live_external_or_irreversible"
          ]
        }
      }
    },
    "strategy_policy": {
      "enum": [
        "frozen_strategy",
        "reviewed_replanning"
      ]
    },
    "gate_mode": {
      "enum": [
        "none",
        "human_gate",
        "live_gate"
      ]
    },
    "phase_structure": {
      "enum": [
        "single_phase",
        "staged",
        "adaptive_loop"
      ]
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "minLength": 1
        },
        "amendment_source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "control_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirements",
        "design",
        "goal",
        "plan",
        "review"
      ],
      "properties": {
        "requirements": {
          "type": "string",
          "minLength": 1
        },
        "design": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "plan": {
          "type": "string",
          "minLength": 1
        },
        "review": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "semantic_base_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "approved_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective",
        "what_counts_as_done"
      ],
      "properties": {
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "what_counts_as_done": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "approved_control_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "registry_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_agent_workflow"
      ],
      "properties": {
        "selected_agent_workflow": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "imported_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invalidated_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readonly_files",
        "writable_files",
        "writable_evidence_paths"
      ],
      "properties": {
        "readonly_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "writable_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "writable_evidence_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "required_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "transition",
          "evidence",
          "satisfies_outcomes"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "transition": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "satisfies_outcomes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "synthetic": {
            "type": "boolean"
          }
        }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_schema",
        "append_only"
      ],
      "properties": {
        "event_schema": {
          "type": "string",
          "minLength": 1
        },
        "append_only": {
          "type": "boolean"
        }
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_before_goal_achieved",
        "command",
        "required_outcomes",
        "output_schema"
      ],
      "properties": {
        "required_before_goal_achieved": {
          "type": "boolean"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "required_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_schema": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
