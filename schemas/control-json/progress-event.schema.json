{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/progress-event.schema.json",
  "title": "Cybernetic Runtime Progress Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "schema_version",
    "occurred_at",
    "runtime_generation"
  ],
  "properties": {
    "event_type": {
      "enum": [
        "step.started",
        "step.completed",
        "step.blocked",
        "step.failed",
        "observation.recorded",
        "runtime.generation.started",
        "runtime.generation.superseded",
        "control.amendment.proposed",
        "control.amendment.approved",
        "control.amendment.rejected",
        "control.amendment.blocked",
        "counterexample.review.completed",
        "verification.completed",
        "final_report.written"
      ]
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "minLength": 1
    },
    "work_package_id": {
      "type": "string",
      "minLength": 1
    },
    "required_step": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "pass",
        "fail",
        "blocked",
        "partial"
      ]
    },
    "verdict": {
      "enum": [
        "approved",
        "needs_revision",
        "blocked"
      ]
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "evidence_ref"
      ],
      "properties": {
        "kind": {
          "enum": [
            "subagent",
            "human",
            "external"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reviewed_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reviewed_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checked_transformations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "progress_role": {
      "enum": [
        "mainline",
        "supporting_only"
      ]
    },
    "counts_as_goal_progress": {
      "type": "boolean"
    },
    "runtime_generation": {
      "type": "string",
      "minLength": 1
    },
    "amendment_id": {
      "type": "string",
      "minLength": 1
    },
    "triggering_observation": {
      "type": "string",
      "minLength": 1
    },
    "affected_stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "design",
          "goal",
          "plan",
          "runtime",
          "verifier"
        ]
      }
    },
    "affected_source_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "semantic_base_change": {
      "type": "boolean"
    },
    "required_outcomes_changed": {
      "type": "boolean"
    },
    "authority_expanded": {
      "type": "boolean"
    },
    "proposed_changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "patch_ref": {
      "type": "string",
      "minLength": 1
    },
    "parent_generation": {
      "type": "string",
      "minLength": 1
    },
    "next_generation": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "corrects_event_ref": {
      "type": "string",
      "minLength": 1
    },
    "classification": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_path": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "counterexample.review.completed"
          }
        }
      },
      "then": {
        "required": [
          "status",
          "verdict",
          "reviewer",
          "reviewed_steps",
          "reviewed_outcomes",
          "checked_transformations",
          "evidence"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "step.started",
              "step.completed",
              "step.blocked",
              "step.failed"
            ]
          }
        }
      },
      "then": {
        "required": [
          "work_package_id",
          "required_step",
          "status",
          "evidence"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "control.amendment.proposed"
          }
        }
      },
      "then": {
        "required": [
          "runtime_generation",
          "amendment_id",
          "reason",
          "triggering_observation",
          "affected_stages",
          "semantic_base_change",
          "required_outcomes_changed",
          "authority_expanded",
          "proposed_changes",
          "review_required",
          "patch_ref"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "control.amendment.proposed"
          },
          "schema_version": {
            "const": "1.1.0"
          }
        }
      },
      "then": {
        "required": [
          "affected_source_requirements"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "runtime.generation.superseded"
          }
        }
      },
      "then": {
        "required": [
          "reason"
        ]
      }
    }
  ]
}
