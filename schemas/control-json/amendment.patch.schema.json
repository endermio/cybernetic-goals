{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/amendment.patch.schema.json",
  "title": "Cybernetic Control Amendment Patch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "amendment_id",
    "parent_generation",
    "strategy_kind",
    "required_steps"
  ],
  "properties": {
    "artifact_type": {
      "const": "amendment.patch"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "amendment_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_generation": {
      "type": "string",
      "minLength": 1
    },
    "strategy_kind": {
      "const": "amendment"
    },
    "required_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "transition",
          "evidence",
          "satisfies_outcomes"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "transition": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "satisfies_outcomes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "synthetic": {
            "type": "boolean"
          }
        }
      }
    },
    "runtime_updates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "writable_evidence_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verifier": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_before_goal_achieved",
            "command",
            "required_outcomes",
            "output_schema"
          ],
          "properties": {
            "required_before_goal_achieved": {
              "type": "boolean"
            },
            "command": {
              "type": "string",
              "minLength": 1
            },
            "required_outcomes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "output_schema": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "imported_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "invalidated_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
