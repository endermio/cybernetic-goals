{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/final-report.schema.json",
  "title": "Cybernetic Runtime Final Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "goal_achieved",
    "what_counts_as_done_met",
    "evidence",
    "verification",
    "work_coverage",
    "remaining_gaps"
  ],
  "properties": {
    "artifact_type": {
      "const": "final-report"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "goal_achieved": {
      "type": "boolean"
    },
        "what_counts_as_done_met": {
            "type": "boolean"
        },
        "runtime_generation": {
            "type": "string",
            "minLength": 1
        },
        "superseded_generations": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "unresolved_amendments": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifier_result",
        "verifier_permits_goal_achieved"
      ],
      "properties": {
        "verifier_result": {
          "enum": [
            "pass",
            "fail",
            "blocked",
            "not_run"
          ]
        },
        "verifier_permits_goal_achieved": {
          "type": "boolean"
        }
      }
    },
    "work_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "executed",
        "prepared_only",
        "forbidden_not_executed",
        "out_of_scope"
      ],
      "properties": {
        "status": {
          "enum": [
            "complete",
            "partial",
            "unavailable",
            "explicitly_bounded"
          ]
        },
        "executed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prepared_only": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_not_executed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "remaining_gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
