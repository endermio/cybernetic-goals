{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybernetic-goals.local/schemas/control-json/design.control.schema.json",
  "title": "Cybernetic Design Control",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "status",
    "source_contracts",
    "semantic_base_ref",
    "approved_control",
    "required_steps"
  ],
  "properties": {
    "artifact_type": {
      "const": "design.control"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "approved",
        "candidate"
      ]
    },
    "source_contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirements"
      ],
      "properties": {
        "requirements": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "semantic_base_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "approved_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirmed_meaning",
        "required_answer_path",
        "what_is_not_enough_avoided"
      ],
      "properties": {
        "confirmed_meaning": {
          "type": "string",
          "minLength": 1
        },
        "required_answer_path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "what_is_not_enough_avoided": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "required_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "transition",
          "evidence",
          "satisfies_outcomes"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "transition": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "satisfies_outcomes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
